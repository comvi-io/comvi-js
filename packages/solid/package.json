{
  "name": "@comvi/solid",
  "version": "0.1.1",
  "type": "module",
  "description": "SolidJS integration for Comvi — reactive primitives and type-safe translations",
  "license": "MIT",
  "author": "Comvi <hello@comvi.io> (https://comvi.io)",
  "repository": {
    "type": "git",
    "url": "https://github.com/comvi-io/comvi-js.git",
    "directory": "packages/solid"
  },
  "homepage": "https://comvi.io",
  "bugs": {
    "url": "https://github.com/comvi-io/comvi-js/issues"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "solidjs",
    "solid",
    "typescript",
    "type-safe",
    "comvi",
    "translation",
    "reactive",
    "ssr",
    "ssg",
    "server-components"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/comvi-solid.cjs",
  "module": "./dist/comvi-solid.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/comvi-solid.js",
      "require": "./dist/comvi-solid.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write src/",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@comvi/core": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@comvi/vite-config": "workspace:*",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "solid-js": "^1.9.12",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.2"
  }
}
