{
  "name": "@comvi/next",
  "version": "0.2.0",
  "type": "module",
  "description": "Next.js App Router integration for Comvi — SSR, middleware, and locale routing",
  "license": "MIT",
  "author": "Comvi <hello@comvi.io> (https://comvi.io)",
  "repository": {
    "type": "git",
    "url": "https://github.com/comvi-io/comvi-js.git",
    "directory": "packages/next"
  },
  "homepage": "https://comvi.io",
  "bugs": {
    "url": "https://github.com/comvi-io/comvi-js/issues"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "nextjs",
    "next",
    "app-router",
    "ssr",
    "typescript",
    "type-safe",
    "comvi",
    "translation",
    "middleware",
    "ssg",
    "server-components"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    },
    "./routing": {
      "types": "./dist/routing.d.ts",
      "import": "./dist/routing.js",
      "require": "./dist/routing.cjs"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.js",
      "require": "./dist/navigation.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write src/",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@comvi/core": "workspace:*",
    "@comvi/react": "workspace:*"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.9",
    "next": "15.5.9",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  }
}
