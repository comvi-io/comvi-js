{
  "name": "@comvi/plugin-in-context-editor",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "In-context translation editor plugin for Comvi — visual editing of translations in your app",
  "license": "MIT",
  "author": "Comvi <hello@comvi.io> (https://comvi.io)",
  "repository": {
    "type": "git",
    "url": "https://github.com/comvi-io/comvi-js.git",
    "directory": "packages/plugin-in-context-editor"
  },
  "homepage": "https://comvi.io",
  "bugs": {
    "url": "https://github.com/comvi-io/comvi-js/issues"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation-editor",
    "in-context",
    "visual-editor",
    "comvi",
    "plugin",
    "localization"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "production": {
        "import": "./dist/production.es.js",
        "require": "./dist/production.cjs.js"
      },
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./standalone": "./dist/standalone.iife.js"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm --filter @comvi/plugin-fetch-loader build && vue-tsc && vite build && vite build --config vite.config.standalone.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "build:standalone": "vite build --config vite.config.standalone.ts",
    "build:all": "pnpm build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "peerDependencies": {
    "@comvi/core": "workspace:*"
  },
  "dependencies": {
    "@comvi/plugin-fetch-loader": "workspace:*",
    "@lucide/vue": "^1.7.0",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.9.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "happy-dom": "^20.8.9",
    "tailwindcss": "4",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
