{
  "name": "@comvi/vue",
  "version": "0.2.0",
  "type": "module",
  "description": "Vue 3 integration for Comvi — composables, components, and type-safe translations",
  "license": "MIT",
  "author": "Comvi <hello@comvi.io> (https://comvi.io)",
  "repository": {
    "type": "git",
    "url": "https://github.com/comvi-io/comvi-js.git",
    "directory": "packages/vue"
  },
  "homepage": "https://comvi.io",
  "bugs": {
    "url": "https://github.com/comvi-io/comvi-js/issues"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "vue",
    "vue3",
    "vue-i18n",
    "composition-api",
    "typescript",
    "type-safe",
    "comvi",
    "translation",
    "ssr",
    "ssg",
    "server-components"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/comvi-vue.cjs",
  "module": "./dist/comvi-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/comvi-vue.js",
      "require": "./dist/comvi-vue.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vue-tsc && vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write src/",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@comvi/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@comvi/vite-config": "workspace:*",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2",
    "vue": "^3.5.32",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  }
}
